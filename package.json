  },
  "scripts": {
    "start": "node dist/waw-mcp.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "optionalDependencies": {
    "playwright": "^1.60.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "email",
    "otp",
    "identity",
    "signup",
    "registry",
    "waw"
  ],
