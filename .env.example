# ─────────────────────────────────────────────────────────────────────────────
# waw-mcp — configuration EXEMPLE. Copier en `.env` et remplir.
# NE JAMAIS committer le `.env` réel (il est git-ignored). Aucun secret en clair
# dans le dépôt : tout passe par des variables d'environnement.
#
# En usage MCP normal, ces variables sont fournies par le bloc `env` de la config
# du client (Claude Code, etc.) — voir README. Le `.env` n'est qu'un confort dev.
# ─────────────────────────────────────────────────────────────────────────────

# OBLIGATOIRE : secret maître du coffre (clé dérivée par scrypt).
VAULT_PASSPHRASE=change-me-use-a-long-random-passphrase

# Domaine sur lequel l'agent provisionne ses adresses e-mail valides.
MAIL_DOMAIN=agents.example.com

# Chemin de la base SQLite. Par défaut : ~/.waw/gateway.db
# Pour PARTAGER la base avec le gateway WAW (réception d'e-mail), pointer ici
# vers le même fichier que le gateway (chemin ABSOLU).
# DB_PATH=/abs/path/to/gateway.db

# Optionnel : pour recevoir de vrais e-mails via le webhook signé du gateway WAW.
# WEBHOOK_SIGNING_SECRET=change-me-webhook-hmac-secret
